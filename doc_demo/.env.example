# COBOL Documentation Pipeline - Environment Configuration


GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Optional: Groq fallback (if you want to swap providers)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Neo4j Connection (OPTIONAL)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ProLeap Parser Settings
PROLEAP_JAR_PATH=lib/proleap-cobol-parser.jar
COBOL_FORMAT=TANDEM
COBOL_DIALECT=IBM_ENTERPRISE

# Documentation Output
DOCS_OUTPUT_DIR=docs
